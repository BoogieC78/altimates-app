# Mode "dev-bypass" de Vite (chargé avec `vite --mode dev-bypass`).
# Connexion automatique sur l'émulateur Auth (voir src/core/firebase/auth.ts,
# devAutoSignIn) : évite de cliquer login à chaque rechargement en dev/QA.
# Nécessite les émulateurs Firebase lancés (`npm run emulators`).
# Ne s'active JAMAIS en prod : import.meta.env.DEV est figé à false au build.
VITE_USE_EMULATOR=1
VITE_DEV_AUTOLOGIN=1
