rules_version = '2';

// Règles de sécurité Firestore — projet altimates-4c37f.
// À déployer depuis la console Firebase (Firestore > Règles) ou via `firebase deploy --only firestore:rules`.
// Le contrôle d'accès réel est ICI, pas dans le code client.

service cloud.firestore {
  match /databases/{database}/documents {

    // Admins : codés en dur À DESSEIN (ancre de sécurité). Toujours membres,
    // même si la whitelist dynamique est vide → jamais de lockout total.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'hammadou.nordine@gmail.com',
          'wacil78@gmail.com'
        ];
    }

    // Whitelist dynamique des membres, éditable depuis le panneau Admin.
    // Source de vérité : config/allowedEmails.emails (string[]).
    function allowedEmails() {
      return exists(/databases/$(database)/documents/config/allowedEmails)
        ? get(/databases/$(database)/documents/config/allowedEmails).data.get('emails', [])
        : [];
    }

    function isMember() {
      return request.auth != null
        && (isAdmin() || request.auth.token.email in allowedEmails());
    }

    // Chaque membre ne peut écrire que son propre document utilisateur.
    match /users/{userId} {
      allow read: if isMember();
      allow write: if isMember()
        && (request.auth.uid == userId || isAdmin());
    }

    // Whitelist lisible par les MEMBRES uniquement (pas par tout compte Google :
    // sinon n'importe qui d'authentifié pourrait énumérer les e-mails membres).
    // Pas de dépendance circulaire : le get() de allowedEmails() dans isMember()
    // s'exécute côté serveur et ignore les règles de lecture. Côté client, un
    // non-membre reçoit permission-denied → isMemberEmail() conclut "non autorisé".
    match /config/allowedEmails {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Disponibilités (onglet Fenêtre) : chacun ne peut écrire que son propre
    // doc (id = uid) ; lecture par tous les membres pour voir les fenêtres communes.
    match /availability/{userId} {
      allow read: if isMember();
      allow write: if isMember() && request.auth.uid == userId;
    }

    // Autres docs de config : lecture membres, écriture admin.
    match /config/{doc} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // Idées (onglet Idées) : vote/statut/commentaires/suppression ouverts à tout
    // membre comme le reste des collections collaboratives, mais le texte et la
    // catégorie ne sont modifiables que par l'auteur (édition après soumission).
    match /feedbacks/{doc} {
      allow read, create, delete: if isMember();
      allow update: if isMember()
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['text', 'cat'])
          || resource.data.author == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile.name);
    }

    // Collections collaboratives : lecture/écriture pour tous les membres.
    match /{collection}/{doc} {
      allow read, write: if isMember()
        && collection in ['randos', 'messages', 'departItems', 'ravito', 'hydra'];
    }
  }
}
