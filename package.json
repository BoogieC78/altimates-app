{
  "name": "altimates-app",
  "private": true,
  "version": "0.3.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "dev:e2e": "vite --mode e2e",
    "dev:bypass": "vite --mode dev-bypass",
    "build:e2e": "vite build --mode e2e",
    "preview:e2e": "vite preview --mode e2e --port 4173 --strictPort --host 127.0.0.1",
    "emulators": "firebase emulators:start --only auth,firestore --project altimates-4c37f",
    "test:e2e": "npm run build:e2e && firebase emulators:exec --only auth,firestore --project altimates-4c37f 'playwright test'",
    "test:e2e:ui": "firebase emulators:exec --only auth,firestore --project altimates-4c37f 'playwright test --ui'"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.23",
    "@vitejs/plugin-react": "^6.0.3",
    "firebase-tools": "^15.23.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "jose": "^5.10.0"
  }
}
